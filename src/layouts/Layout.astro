---
import "../assets/app.css";
import "@fortawesome/fontawesome-free/css/all.min.css";
import Navbar from '@/components/Navbar/Navbar.astro';
import Footer from '@/components/Footer.astro';
import ScrollToTop from '@/components/ScrollToTop.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Game Guides - Guías de Videojuegos',
  description = 'Guías de videojuegos creadas por un gamer para gamers. Nunca más pierdas el hilo de tu partida.',
} = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
	</head>
	<body class="flex flex-col min-h-screen">
		<Navbar />

		<main class="flex-1">
			<slot />
		</main>

		<Footer />

		<ScrollToTop />

		<div id="toast-container" class="toast toast-end z-10 hidden">
			<div id="toast-alert"
			     class="flex items-center gap-3 px-5 py-3 rounded-2xl backdrop-blur-md border bg-linear-to-r from-error/20 to-error/10 border-error shadow-lg shadow-error/30 min-w-64">
				<i id="toast-icon" class="fa-solid fa-circle-exclamation text-error text-lg"></i>
				<span id="toast-message" class="text-white text-sm font-medium flex-1">Error Message</span>
				<button id="toast-close" class="text-white/40 hover:text-white/70 transition-colors text-lg leading-none">&times;</button>
			</div>
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
