---
import logo from '@/assets/images/logo.png';
---

<footer class="border-t border-white/5"
        style="background: rgba(10, 10, 15, 0.8); backdrop-filter: blur(20px);">
  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
    <div class="grid sm:grid-cols-2 gap-8 mb-10">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src={logo.src} alt="Game Guides" class="w-8 h-8 object-contain" />
          <span class="font-gaming text-sm font-bold text-white">
            Game<span class="text-emerald-400">Guides</span>
          </span>
        </div>
        <p class="text-gray-500 text-sm max-w-sm">Guías de videojuegos creadas por un gamer para gamers. Nunca más pierdas el hilo de tu partida.</p>
      </div>
      <div>
        <h4 class="text-white text-sm font-semibold mb-4">Redes</h4>
        <div class="flex gap-3">
          <a href="https://www.youtube.com/@TheNefelin" target="_blank"
             class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-gray-400 hover:bg-red-500/20 hover:text-red-500 transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.47 3.5 12 3.5 12 3.5s-7.47 0-9.38.55A3.02 3.02 0 0 0 .5 6.19 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.81 3.02 3.02 0 0 0 2.12 2.14c1.91.55 9.38.55 9.38.55s7.47 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.81zM9.55 15.57V8.43L15.82 12l-6.27 3.57z"/>
            </svg>
          </a>
          <a href="https://github.com/TheNefelin" target="_blank"
             class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-gray-400 hover:bg-white/20 hover:text-white transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.twitch.tv/TheNefelin" target="_blank"
             class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-gray-400 hover:bg-purple-500/20 hover:text-purple-500 transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
    <div class="border-t border-white/5 pt-6 text-center">
      <p class="text-gray-400 text-sm">© 2026 <a href="https://www.francisco-dev.cl" target="_blank" class="hover:text-emerald-400 transition-colors">francisco-dev.cl</a></p>
    </div>
  </div>
</footer>
