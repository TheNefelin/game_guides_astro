<button id="scrollTop"
        class="fixed bottom-6 right-6 w-12 h-12 rounded-full bg-linear-to-br from-emerald-400 to-cyan-400 shadow-lg shadow-emerald-500/20 flex items-center justify-center text-black hover:scale-110 transition-transform z-[60] opacity-0 pointer-events-none">
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('scrollTop') as HTMLButtonElement;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 200) {
      btn.classList.remove('opacity-0', 'pointer-events-none');
    } else {
      btn.classList.add('opacity-0', 'pointer-events-none');
    }
  });

  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
