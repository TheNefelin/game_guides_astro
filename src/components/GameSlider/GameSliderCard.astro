---
interface Game {
  name: string;
  slug: string;
  cover_url: string;
  genre_name: string;
}

interface Props {
  game: Game;
}

const { game } = Astro.props;
---

<div class="glass-card rounded-xl p-3 flex flex-col items-center gap-2 transition-all cursor-pointer relative">
  <div class="absolute inset-0 rounded-xl bg-base-100/40 pointer-events-none"></div>
  <div class="relative z-10 flex flex-col items-center gap-2">
    <div class="w-24 h-24 rounded-xl overflow-hidden bg-base-300 ring-2 ring-base-content/5 group-hover:ring-accent/30 transition-all">
    <img
      src={game.cover_url}
      alt={game.name}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      loading="lazy"
      width="96"
      height="96"/>
    </div>
    <span class="text-base-content text-xs font-semibold text-center leading-tight">{game.name}</span>
    <span class="text-base-content/40 text-[10px]">{game.genre_name}</span>
  </div>
</div>
