---
import GameSliderCard from "./GameSliderCard.astro";

interface Game {
  name: string;
  slug: string;
  cover_url: string;
  genre_name: string;
}

interface Props {
  games: Game[];
}

const { games } = Astro.props;
---

<section class="pt-20 pb-2 relative z-10">
  <div class="max-w-7xl mx-auto px-4 lg:px-4">
    <div class="flex items-center justify-between px-4">
      <span class="text-base-content/50 text-xs font-medium uppercase tracking-widest flex items-center gap-2">
        <i class="fa-solid fa-bolt text-primary text-xs"></i>
        Acceso Rápido
      </span>
      <div class="flex gap-1">
        <button class="w-7 h-7 rounded-full bg-base-content/5 border border-base-content/10 flex items-center justify-center text-base-content/60 hover:text-primary hover:border-primary/30 transition-all swiper-quick-prev">
          <i class="fa-solid fa-chevron-left text-xs"></i>
        </button>
        <button class="w-7 h-7 rounded-full bg-base-content/5 border border-base-content/10 flex items-center justify-center text-base-content/60 hover:text-primary hover:border-primary/30 transition-all swiper-quick-next">
          <i class="fa-solid fa-chevron-right text-xs"></i>
        </button>
      </div>
    </div>
    <div class="swiper quickSwiper">
      <div class="swiper-wrapper p-4">
        {
          games.map((game) => (
            <a href={`/game/${game.slug}`} class="swiper-slide group">
              <GameSliderCard game={game} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';

  new Swiper('.quickSwiper', {
    modules: [Navigation],
    slidesPerView: 3,
    spaceBetween: 12,
    slidesOffsetAfter: 32,
    grabCursor: true,
    navigation: {
      nextEl: '.swiper-quick-next',
      prevEl: '.swiper-quick-prev',
    },
    breakpoints: {
      480: { slidesPerView: 4, spaceBetween: 12 },
      640: { slidesPerView: 4.5, spaceBetween: 14 },
      768: { slidesPerView: 5, spaceBetween: 16 },
      900: { slidesPerView: 5.5, spaceBetween: 16 },
      1024: { slidesPerView: 6, spaceBetween: 16 },
    },
  });
</script>
