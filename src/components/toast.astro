<div id="toast-container" class="toast toast-end z-10 hidden">
  <div id="toast-alert"
       class="flex items-center gap-3 px-5 py-3 rounded-2xl backdrop-blur-md border bg-linear-to-r from-error/20 to-error/10 border-error shadow-lg shadow-error/30 min-w-64">
    <i id="toast-icon" class="fa-solid fa-circle-exclamation text-error text-lg"></i>
    <span id="toast-message" class="text-white text-sm font-medium flex-1">Error Message</span>
    <button id="toast-close" class="text-white/40 hover:text-white/70 transition-colors text-lg leading-none">&times;</button>
  </div>
</div>

