---
import logo from '@/assets/images/logo.png';
import NavThemeToggle from './NavThemeToggle.astro';
import NavLinks from './NavLinks.astro';
import AuthGoogle from './AuthGoogle.astro';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/guias', label: 'Guias' },
  { href: '/categorias', label: 'Categorias' },
  { href: '/contacto', label: 'Contacto' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 px-4 lg:px-8 border-b border-white/5"
     style="background: rgba(10, 10, 15, 0.8); backdrop-filter: blur(20px);">
  <div class="max-w-7xl mx-auto flex items-center justify-between h-16">
    <div class="flex items-center gap-3">
      <img src={logo.src} alt="Game Guides" class="w-10 h-10 object-contain" />
      <span class="font-gaming text-lg font-bold tracking-wider text-white block">
        Game<span class="text-emerald-400">Guides</span>
      </span>
      <NavThemeToggle />
    </div>

    <NavLinks links={navLinks} />

    <div class="flex items-center gap-3">
      <AuthGoogle />

      <label for="mobileDrawer" class="text-gray-300 hover:text-emerald-400 md:hidden cursor-pointer">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </label>
    </div>
  </div>
</nav>

<div class="drawer drawer-end z-40">
  <input id="mobileDrawer" type="checkbox" class="drawer-toggle" />
  <div class="drawer-side">
    <label for="mobileDrawer" aria-label="close sidebar" class="drawer-overlay"></label>
    <div class="flex flex-col min-h-full w-64 p-4 pt-20 border-l border-white/5"
         style="background: rgba(10, 10, 15, 0.97); backdrop-filter: blur(20px);">
      {
        navLinks.map((link) => (
          <a href={link.href}
             class="block py-3 text-gray-300 hover:text-emerald-400 transition-colors text-sm font-medium"
             onclick="document.getElementById('mobileDrawer').checked = false">
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</div>
