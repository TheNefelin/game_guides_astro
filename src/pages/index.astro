---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero/Hero.astro';
import GameSlider from '@/components/GameSlider/GameSlider.astro';
import WelcomeParallax from '@/components/WelcomeParallax/WelcomeParallax.astro';
import FeaturedGames from '@/components/FeaturedGames/FeaturedGames.astro';
import Stats from '@/components/Stats/Stats.astro';

let games: { name: string; slug: string; cover_url: string; genre_name: string }[] = [];
let featuredGames: any[] = [];

try {
  const res = await fetch(`${Astro.url.origin}/api/games?page=1&limit=10`);

  if (res.ok) {
    const data = await res.json();
    if (data?.items) {
      games = data.items.map((g: any) => ({
        name: g.name,
        slug: g.slug,
        cover_url: g.cover_url ?? '',
        genre_name: g.genres?.[0]?.name ?? '',
      }));
      featuredGames = data.items;
    }
  }
} catch (err) {
  console.error('Error fetching games:', err);
}
---

<Layout 
  title="Inicio - Game Guides" 
  description="Guías detalladas, secretos y misiones paso a paso para tus juegos favoritos.">
  
  <GameSlider games={games} />

  <Hero />

  <Stats />

  <WelcomeParallax />

  <FeaturedGames games={featuredGames} />

</Layout>
